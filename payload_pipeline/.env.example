# Copy to `.env`. The .env file is gitignored; never commit real keys.
# Read by the real `meta` adapter. Mock ignores these.

META_ACCESS_TOKEN=          # long-lived token from Events Manager OR a system-user token
META_APP_SECRET=            # only needed if you enable app_secret_proof (recommended for production)
META_AD_ACCOUNT_ID=         # digits only, no act_ prefix
META_PAGE_ID=               # the FB Page running the ads
META_INSTAGRAM_ACTOR_ID=    # optional, for IG placements
META_PIXEL_ID=              # required only when OUTCOME_SALES / OFFSITE_CONVERSIONS enabled
META_API_VERSION=v19.0      # override if you want a specific Graph API version
